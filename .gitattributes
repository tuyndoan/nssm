# Normalize line endings; Git decides text vs binary automatically.
* text=auto

# Windows tooling requires CRLF.
*.cmd   text eol=crlf
*.bat   text eol=crlf
*.sln   text eol=crlf
*.vcproj text eol=crlf
*.vcxproj text eol=crlf
# Message/resource scripts are UTF-16LE on disk; mc.exe requires that encoding.
# Do not let Git normalize line endings (breaks mc on CI checkout).
*.rc    -text
*.mc    -text

# C/C++ sources (LF in repo, normalized on checkout).
*.c     text
*.cpp   text
*.h     text

# Web docs.
*.html  text
*.css   text
*.js    text
*.md    text

# Show readable diffs for resource/message scripts.
*.rc    diff
*.mc    diff

# Binary assets — never normalize.
*.ico   binary
*.bin   binary
*.png   binary
*.jpg   binary
*.gif   binary
*.exe   binary
*.pdb   binary
*.res   binary
